# 🤖 Discord Bot Hosting - الإعدادات
# انسخ هذا الملف إلى .env وعدل القيم

# كلمة مرور لوحة التحكم (تغييرها إلزامي للأمان)
ADMIN_PASSWORD=admin123

# مفتاح تشفير Flask (يستخدم للجلسات)
SECRET_KEY=discord-bot-hosting-secret-key-change-me

# منفذ الخادم (اختياري، الافتراضي 5000)
PORT=5000

# وضع التصحيح (true/false)
DEBUG=false
